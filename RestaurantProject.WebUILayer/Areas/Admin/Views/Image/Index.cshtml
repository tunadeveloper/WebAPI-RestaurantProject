@using RestaurantProject.WebUILayer.DTOs.ImageDTOs
@model List<ResultImageDTO>

@{
    ViewData["Title"] = "Görsel Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int id = 0;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Görsel Tablosu</h4>
                <a href="/Admin/Image/CreateImage" class="btn btn-success">Görsel Oluştur</a>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <tr>
                            <th class="text-center">#</th>
                            <th>Görsel</th>
                            <th>Başlık</th>
                            <th>URL</th>
                            <th>İşlem</th>
                        </tr>

                        @foreach (var item in Model)
                        {
                            id++;
                            <tr>
                                <td class="p-0 text-center">@id</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@(item.ImageTitle ?? "")" class="img-thumbnail" style="max-width:80px;max-height:80px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>@item.ImageTitle</td>
                                <td class="small text-break">@item.ImageUrl</td>
                                <td>
                                    <a href="/Admin/Image/DeleteImage/@item.Id" class="btn btn-danger btn-sm">Sil</a>
                                    <a href="/Admin/Image/UpdateImage/@item.Id" class="btn btn-primary btn-sm">Güncelle</a>
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
