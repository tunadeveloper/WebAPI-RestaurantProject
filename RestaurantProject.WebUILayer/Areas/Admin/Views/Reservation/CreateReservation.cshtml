@using RestaurantProject.WebUILayer.DTOs.ReservationDTOs
@model CreateReservationDTO

@{
    ViewData["Title"] = "Yeni Rezervasyon";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4>Yeni Rezervasyon Ekle</h4>
            </div>
            <div class="card-body">
                <form asp-action="CreateReservation" asp-area="Admin" asp-controller="Reservation" method="post">
                    <div class="form-group">
                        <label for="ReservationNameSurname">Ad Soyad</label>
                        <input type="text" class="form-control" id="ReservationNameSurname" name="ReservationNameSurname" placeholder="Ad Soyad" />
                    </div>
                    <div class="form-group">
                        <label for="ReservationEmail">E-posta</label>
                        <input type="email" class="form-control" id="ReservationEmail" name="ReservationEmail" placeholder="E-posta" />
                    </div>
                    <div class="form-group">
                        <label for="ReservationPhoneNumber">Telefon</label>
                        <input type="text" class="form-control" id="ReservationPhoneNumber" name="ReservationPhoneNumber"  placeholder="Telefon" />
                    </div>
                    <div class="form-group">
                        <label for="ReservationDate">Tarih ve Saat</label>
                        <input type="datetime-local" class="form-control" id="ReservationDate" name="ReservationDate"  />
                    </div>
                    <div class="form-group">
                        <label for="ReservationCountOfPeople">Kişi Sayısı</label>
                        <input type="number" class="form-control" id="ReservationCountOfPeople" name="ReservationCountOfPeople"  min="1" placeholder="Kişi sayısı" />
                    </div>
                    <div class="form-group">
                        <label for="ReservationMessage">Mesaj</label>
                        <textarea class="form-control" id="ReservationMessage" name="ReservationMessage" rows="3" placeholder="Mesaj"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="ReservationStatus">Durum</label>
                        <select class="form-control" id="ReservationStatus" name="ReservationStatus">
                            <option value="Beklemede">Beklemede</option>
                            <option value="Onaylandı">Onaylandı</option>
                            <option value="İptal Edildi">İptal Edildi</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Rezervasyon Oluştur</button>
                    <a href="/Admin/Reservation/Index" class="btn btn-secondary">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>
