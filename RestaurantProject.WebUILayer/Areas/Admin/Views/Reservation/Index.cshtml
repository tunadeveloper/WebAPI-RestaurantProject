@using RestaurantProject.WebUILayer.DTOs.ReservationDTOs
@model List<ResultReservationDTO>

@using System.Globalization
@{
    ViewData["Title"] = "Rezervasyon Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int id = 0;
    var tr = CultureInfo.GetCultureInfo("tr-TR");
}
<style>
    .reservation-users-icon { color: #e67e22 !important; }
</style>
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Rezervasyon Tablosu</h4>
                <a href="/Admin/Reservation/CreateReservation" class="btn btn-success">Rezervasyon Oluştur</a>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <tr>
                            <th class="text-center">#</th>
                            <th>Ad Soyad</th>
                            <th><i class="fas fa-users mr-1 reservation-users-icon"></i> Kişi Sayısı</th>
                            <th><i class="fas fa-calendar-alt mr-1 text-info"></i> Tarih</th>
                            <th><i class="fas fa-clock mr-1 text-success"></i> Saat</th>
                            <th>Durum</th>
                            <th>İşlem</th>
                        </tr>

                        @foreach (var item in Model)
                        {
                            id++;
                            var statusNorm = (item.ReservationStatus ?? "").ToLower(tr);
                            var isCancel = statusNorm.Contains("iptal");
                            var isApproval = statusNorm.Contains("onay");
                            var statusIcon = isCancel ? "fas fa-times-circle" : isApproval ? "fas fa-check-circle" : "fas fa-hourglass-half";
                            <tr>
                                <td class="p-0 text-center">@id</td>
                                <td>@item.ReservationNameSurname</td>
                                <td><i class="fas fa-users mr-1 reservation-users-icon"></i><span style="color:#2c3e50;">@item.ReservationCountOfPeople kişi</span></td>
                                <td><i class="fas fa-calendar-alt text-info mr-1"></i>@item.ReservationDate.ToString("dd MMMM yyyy")</td>
                                <td><i class="fas fa-clock text-success mr-1"></i>@item.ReservationDate.ToString("HH:mm")</td>
                                <td>
                                    <div class="badge badge-@(isCancel ? "danger" : isApproval ? "success" : "warning")"><i class="@statusIcon mr-1"></i>@item.ReservationStatus</div>
                                </td>
                                <td>
                                    <a href="/Admin/Reservation/DeleteReservation/@item.Id" class="btn btn-danger btn-sm"><i class="fas fa-trash-alt mr-1"></i>Sil</a>
                                    <a href="/Admin/Reservation/UpdateReservation/@item.Id" class="btn btn-primary btn-sm"><i class="fas fa-eye mr-1"></i>Detaylar</a>
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>