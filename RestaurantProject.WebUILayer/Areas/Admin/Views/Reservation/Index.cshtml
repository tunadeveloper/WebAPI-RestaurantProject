@using RestaurantProject.WebUILayer.DTOs.ReservationDTOs
@model List<ResultReservationDTO>

@{
    ViewData["Title"] = "Rezervasyon Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int id = 0;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Rezervasyon Tablosu</h4>
                <a href="/Admin/Reservation/CreateReservation" class="btn btn-success">Rezervasyon Oluştur</a>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <tr>
                            <th class="text-center">
                               #
                            </th>
                            <th>Ad Soyad</th>
                            <th>Kişi Sayısı</th>
                            <th>Tarih</th>
                            <th>Saat</th>
                            <th>Durum</th>
                            <th>İşlem</th>
                        </tr>

                        @foreach (var item in Model)
                        {
                            id++;
                            <tr>
                                <td class="p-0 text-center"> @id
                                </td>

                                <td>@item.ReservationNameSurname</td>
                                <td>@item.ReservationCountOfPeople kişi</td>
                                <td>@item.ReservationDate.ToString("dd MMMM yyyy")</td>
                                <td>@item.ReservationDate.ToString("HH:mm")</td>
                                <td>
                                    <div class="badge badge-@(item.ReservationStatus == "İptal Edildi" ? "danger" : item.ReservationStatus == "Onaylandı" ? "success" : "warning")">@item.ReservationStatus</div>
                                </td>

                                <td>
                                    <a href="/Admin/Reservation/DeleteReservation/@item.Id" class="btn btn-danger">Sil</a>
                                    <a href="/Admin/Reservation/UpdateReservation/@item.Id" class="btn btn-primary">Detaylar</a>
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>