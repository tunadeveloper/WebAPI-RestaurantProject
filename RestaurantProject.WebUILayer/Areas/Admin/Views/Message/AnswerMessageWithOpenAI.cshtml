@using RestaurantProject.WebUILayer.DTOs.MessageDTOs
@model ResultMessageDTO

@{
    ViewData["Title"] = "Yapay Zeka ile Mesaj Yanıtı";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var answerAI = ViewBag.answerAI as string;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4>Yapay Zeka ile Mesaj Yanıtı Oluştur</h4>
            </div>
            <div class="card-body">
                    <div class="form-group">
                        <label>Gönderen</label>
                        <input type="text" class="form-control" value="@Model.MessageNameSurname" readonly />
                    </div>
                    <div class="form-group">
                        <label>E-posta</label>
                        <input type="email" class="form-control" value="@Model.MessageEmail" readonly />
                    </div>
                    <div class="form-group">
                        <label>Konu</label>
                        <input type="text" class="form-control" value="@Model.MessageSubject" readonly />
                    </div>
                    <div class="form-group">
                        <label>Tarih</label>
                        <input type="text" class="form-control" value="@Model.MessageSendDate.ToString("dd.MM.yyyy HH:mm")" readonly />
                    </div>
                    <div class="form-group">
                        <label>Mesaj İçeriği</label>
                        <textarea class="form-control" rows="4" readonly>@Model.MessageDetails</textarea>
                    </div>
                    <form asp-action="AnswerMessageWithOpenAI" asp-area="Admin" asp-controller="Message" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="MessageDetails" value="@Model.MessageDetails" />
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-magic"></i> Yapay Zeka ile Yanıt Oluştur
                        </button>
                        <a href="/Admin/Message/Index" class="btn btn-secondary">Mesaj Listesine Dön</a>
                    </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(answerAI))
        {
            <div class="card mt-4">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Yapay Zeka Yanıtı</h4>
                </div>
                <div class="card-body">
                    <div class="ai-answer-content" style="white-space: pre-line;">@answerAI</div>
                </div>
            </div>
        }
    </div>
</div>
