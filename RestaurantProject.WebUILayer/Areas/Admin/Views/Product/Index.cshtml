@using RestaurantProject.WebUILayer.DTOs.ProductDTOs
@model List<ResultProductDTO>

@{
    ViewData["Title"] = "Ürün Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int id = 0;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Ürün Tablosu</h4>
                <a href="/Admin/Product/CreateProduct" class="btn btn-success">Ürün Oluştur</a>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <tr>
                            <th class="text-center">#</th>
                            <th>Ürün Adı</th>
                            <th>Açıklama</th>
                            <th>Fiyat</th>
                            <th>Kategori</th>
                            <th>İşlem</th>
                        </tr>

                        @foreach (var item in Model)
                        {
                            id++;
                            <tr>
                                <td class="p-0 text-center">@id</td>
                                <td>@item.ProductName</td>
                                <td>@item.ProductDescription</td>
                                <td>@item.ProductPrice</td>
                                <td>@item.CategoryName</td>
                                <td>
                                    <a href="/Admin/Product/DeleteProduct/@item.Id" class="btn btn-danger">Sil</a>
                                    <a href="/Admin/Product/UpdateProduct/@item.Id" class="btn btn-primary">Güncelle</a>
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
