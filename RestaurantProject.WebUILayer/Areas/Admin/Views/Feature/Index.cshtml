@using RestaurantProject.WebUILayer.DTOs.FeatureDTOs
@model List<ResultFeatureDTO>

@{
    ViewData["Title"] = "Özellik Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int id = 0;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Özellik Tablosu</h4>
                <a href="/Admin/Feature/CreateFeature" class="btn btn-success">Özellik Oluştur</a>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <tr>
                            <th class="text-center">#</th>
                            <th>Alt Başlık</th>
                            <th>Açıklama</th>
                            <th>İşlem</th>
                        </tr>

                        @foreach (var item in Model)
                        {
                            id++;
                            <tr>
                                <td class="p-0 text-center">@id</td>
                                <td>@item.FeatureSubtitle</td>
                                <td>@item.FeatureDescription</td>
                                <td>
                                    <a href="/Admin/Feature/DeleteFeature/@item.Id" class="btn btn-danger">Sil</a>
                                    <a href="/Admin/Feature/UpdateFeature/@item.Id" class="btn btn-primary">Güncelle</a>
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
