@using RestaurantProject.WebUILayer.DTOs.ServiceDTOs
@model List<ResultServiceDTO>

<section id="why-us" class="why-us section light-background">
    <div class="container">
        <div class="row gy-4">
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                <div class="why-box">
                    <h3>Neden Yummy?</h3>
                    <p>
                        Kaliteli hizmet, taze ve doğal malzemeler ile hazırlanan eşsiz lezzetler ve alanında uzman şeflerimizle fark yaratıyoruz.
                        Her tabakta özenle seçilmiş ürünler, titizlikle hazırlanmış tarifler ve sunum sanatı bir araya geliyor.
                        Misafirlerimize sadece yemek sunmuyor, aynı zamanda unutulmaz bir gastronomi deneyimi yaşatmayı hedefliyoruz.
                        Yummy’de her öğün; her detayında kalite, hijyen ve servis mükemmelliği ön plandadır.
                    </p>
                    <div class="text-center">
                        <a href="#" class="more-btn"><span>Daha Fazla</span> <i class="bi bi-chevron-right"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-lg-8 d-flex align-items-stretch">
                <div class="row gy-4" data-aos="fade-up" data-aos-delay="200">
                    @foreach (var service in Model)
                    {
                        <div class="col-xl-4" data-aos="fade-up" data-aos-delay="@(200 + Model.IndexOf(service) * 100)">
                            <div class="icon-box d-flex flex-column justify-content-center align-items-center">
                                <i class="@service.ServiceIconUrl"></i>
                                <h4>@service.ServiceTitle</h4>
                                <p>@service.ServiceDescription</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>