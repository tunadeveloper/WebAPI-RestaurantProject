@using RestaurantProject.WebUILayer.DTOs.ReservationDTOs
@model CreateReservationDTO

<section id="book-a-table" class="book-a-table section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Masa Rezervasyonu</h2>
        <p><span>Bizimle</span> <span class="description-title">Yemek Planlayın<br></span></p>
    </div>
    <div class="container">
        <div class="row g-0" data-aos="fade-up" data-aos-delay="100">

            <div class="col-lg-4 reservation-img" style="background-image: url(/yummy-red-1.0.0/assets/img/reservation.jpg); min-height: 400px; background-size: cover; background-position: center;"></div>

            <div class="col-lg-8 d-flex align-items-center reservation-form-bg" data-aos="fade-up" data-aos-delay="200" style="padding: 20px; background-color: #f9f9f9; border-radius: 8px;">
                <form asp-action="CreateReservation" asp-controller="Reservation" method="post" role="form" style="width: 100%;">
                    <div class="row" style="gap: 15px;">

                        <div class="col-lg-4 col-md-6">
                            <input type="text" name="ReservationNameSurname" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;" placeholder="Adınız Soyadınız" required />
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="email" name="ReservationEmail" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;" placeholder="E-posta Adresiniz" required />
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="text" name="ReservationPhoneNumber" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;" placeholder="Telefon Numaranız" required />
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="datetime-local" name="ReservationDate" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;" required />
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <input type="number" name="ReservationCountOfPeople" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;" placeholder="Kişi Sayısı" required />
                        </div>
                        <input type="hidden" name="ReservationStatus" />

                    </div>

                    <div class="form-group mt-3">
                        <textarea name="ReservationMessage" rows="5" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px;" placeholder="Mesajınız"></textarea>
                    </div>

                    <div class="text-center mt-3">
                        <button type="submit" style="
                            background-color: #e74c3c;
                            color: white;
                            padding: 12px 25px;
                            border: none;
                            border-radius: 5px;
                            cursor: pointer;
                            font-weight: bold;
                            transition: background 0.3s;
                        " onmouseover="this.style.backgroundColor='#c0392b'" onmouseout="this.style.backgroundColor='#e74c3c'">
                            Rezervasyonu Oluştur
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</section>