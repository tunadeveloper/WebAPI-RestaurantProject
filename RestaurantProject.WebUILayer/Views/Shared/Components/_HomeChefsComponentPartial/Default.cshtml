@using RestaurantProject.WebUILayer.DTOs.ChefDTOs
@model List<ResultChefDTO>
@{
    int delay = 100;
}
<section id="chefs" class="chefs section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Şeflerimiz</h2>
        <p><span>Usta</span> <span class="description-title">Şeflerimiz<br></span></p>
    </div>

    <div class="container">

        <div class="row gy-4">
            @foreach(var item in Model)
            {
                <div class="col-lg-4 d-flex align-items-stretch" data-aos="fade-up" data-aos-delay="@delay">
                    <div class="team-member">
                        <div class="member-img">
                            <img src="@item.ChefImageUrl" class="img-fluid" alt="">
                            <div class="social">
                                <a href=""><i class="bi bi-twitter-x"></i></a>
                                <a href=""><i class="bi bi-facebook"></i></a>
                                <a href=""><i class="bi bi-instagram"></i></a>
                                <a href=""><i class="bi bi-linkedin"></i></a>
                            </div>
                        </div>
                        <div class="member-info">
                            <h4>@item.ChefNameSurname</h4>
                            <span>@item.ChefTitle</span>
                            <p>@item.ChefDescription</p>
                        </div>
                    </div>
                </div>

                delay += 100;
            }
           
        </div>
    </div>
</section>
